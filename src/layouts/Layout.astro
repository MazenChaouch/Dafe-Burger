---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Dafe's Burger — Best Burger in Town",
  description = "Dafe's Burger — fresh ingredients, unbeatable flavor. Order the best burger in town.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FF0000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
