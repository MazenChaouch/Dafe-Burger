---
// Footer – last item in the scroll container
---

<footer class="relative w-full shrink-0 snap-start bg-[#111111] px-8 py-24">
  <!-- Top accent line -->
  <div
    class="absolute top-0 right-0 left-0 h-px bg-linear-to-r from-transparent via-yellow-400/40 to-transparent"
  >
  </div>

  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="col-span-2 flex flex-col gap-6">
        <div class="flex flex-col leading-none">
          <span
            class="text-4xl font-black tracking-wide text-yellow-400 md:text-6xl"
            >Dafe's</span
          >
          <span
            class="-mt-1 ml-4 text-4xl font-black tracking-wide text-white md:ml-8 md:text-6xl"
            >burger</span
          >
        </div>
        <p class="max-w-md text-base leading-relaxed text-white/60">
          Bold, juicy burgers made with passion in the heart of Tunis. Every
          patty hand-pressed daily. Every sauce mixed in-house. This is a love
          letter to good food.
        </p>
        <div class="mt-2 flex gap-4">
          <a
            href="https://instagram.com/dafesburger"
            aria-label="Instagram"
            class="flex size-10 items-center justify-center rounded-full border border-white/10 text-white/50 transition hover:border-yellow-400 hover:text-yellow-400"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              ></path></svg
            >
          </a>
          <a
            href="https://tiktok.com/@dafesburger"
            aria-label="TikTok"
            class="flex size-10 items-center justify-center rounded-full border border-white/10 text-white/50 transition hover:border-yellow-400 hover:text-yellow-400"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"
              ><path
                d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.79a8.18 8.18 0 004.78 1.53V6.87a4.85 4.85 0 01-1.01-.18z"
              ></path></svg
            >
          </a>
          <a
            href="https://wa.me/21671123456"
            aria-label="WhatsApp"
            class="flex size-10 items-center justify-center rounded-full border border-white/10 text-white/50 transition hover:border-yellow-400 hover:text-yellow-400"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div class="flex flex-col gap-4">
        <h3 class="text-sm font-bold tracking-widest text-white/40 uppercase">
          Quick Links
        </h3>
        <nav class="flex flex-col gap-2">
          {
            [
              { label: "Home", href: "/#slide-1" },
              { label: "Our Menu", href: "/menu" },
              { label: "About Us", href: "/about" },
              { label: "Location", href: "/#slide-5" },
              { label: "Reviews", href: "/#slide-6" },
            ].map((l) => (
              <a
                href={l.href}
                class="text-sm text-white/50 transition hover:text-yellow-400"
              >
                {l.label}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Contact -->
      <div class="flex flex-col gap-4">
        <h3 class="text-sm font-bold tracking-widest text-white/40 uppercase">
          Contact
        </h3>
        <div class="flex flex-col gap-3 text-sm text-white/50">
          <p class="flex items-start gap-2">
            <span class="mt-0.5">📍</span>
            <span>42 Av. Habib Bourguiba<br />Tunis 1000, Tunisia</span>
          </p>
          <a
            href="tel:+21671123456"
            class="flex items-center gap-2 transition hover:text-yellow-400"
          >
            <span>📞</span> +216 71 123 456
          </a>
          <a
            href="mailto:hello@dafesburger.tn"
            class="flex items-center gap-2 transition hover:text-yellow-400"
          >
            <span>✉️</span> hello@dafesburger.tn
          </a>
          <p class="flex items-center gap-2">
            <span>🕐</span> Open daily 11:00 – 23:00
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-12 flex items-center justify-between border-t border-white/5 pt-6"
    >
      <p class="text-xs text-white/25">
        © 2026 Dafe's Burger – Tunis. All rights reserved.
      </p>
      <p class="text-xs text-white/20">Handcrafted in Tunis 🇹🇳</p>
    </div>
  </div>
</footer>
