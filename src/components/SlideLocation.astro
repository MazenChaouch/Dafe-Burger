---
import { SLIDE_LOCATION_DATA } from "../data/home";
const { title, subtitle, address, contact, hours, mapUrl, directionsUrl } =
  SLIDE_LOCATION_DATA;
---

<section
  id="slide-5"
  class="snap-section relative flex h-screen w-full shrink-0 items-center justify-center overflow-hidden bg-[#1a2b40]"
>
  <!-- Background glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute right-0 bottom-0 h-96 w-96 rounded-full bg-yellow-400/5 blur-3xl"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-0 left-0 h-64 w-64 rounded-full bg-red-600/5 blur-3xl"
  >
  </div>

  <div
    class="relative z-10 flex w-full max-w-5xl flex-col items-center gap-10 px-8"
  >
    <div class="flex flex-col items-center gap-2 text-center">
      <span
        class="text-sm font-semibold tracking-[0.3em] text-yellow-400 uppercase"
        >{subtitle}</span
      >
      <h2 class="main-text text-[6vh] font-black text-white">
        {title.split(" ")[0]}
        <span class="text-yellow-400">{title.split(" ")[1]}</span>
      </h2>
    </div>

    <div class="grid w-full grid-cols-2 gap-8">
      <!-- Left: Map + Address -->
      <div class="flex flex-col gap-5">
        <!-- Map placeholder -->
        <div
          class="relative aspect-video overflow-hidden rounded-2xl border border-white/10 bg-white/5"
        >
          <iframe
            src={mapUrl}
            class="h-full w-full border-0 grayscale"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`${title} location on map`}></iframe>
          <!-- Dark overlay to match theme -->
          <div
            class="pointer-events-none absolute inset-0 bg-[#0D1B2A]/30 mix-blend-multiply"
          >
          </div>
        </div>

        <!-- Address block -->
        <div
          class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm"
        >
          <div class="flex items-start gap-3">
            <span class="mt-0.5 text-2xl">📍</span>
            <div>
              <p class="text-sm font-bold tracking-wide text-white">
                {address.line1}
              </p>
              <p class="text-sm text-white/50">{address.line2}</p>
            </div>
          </div>
          <div class="mt-4 flex flex-wrap gap-4">
            <a
              href={`tel:${contact.phone.replace(/\s+/g, "")}`}
              class="flex items-center gap-2 text-sm text-white/70 transition hover:text-yellow-400"
            >
              <span>📞</span>
              {contact.phone}
            </a>
            <a
              href={`https://instagram.com/${contact.instagram.replace("@", "")}`}
              class="flex items-center gap-2 text-sm text-white/70 transition hover:text-yellow-400"
            >
              <span>📷</span>
              {contact.instagram}
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Hours -->
      <div class="flex flex-col gap-4">
        <div
          class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm"
        >
          <h3
            class="mb-4 text-base font-bold tracking-widest text-yellow-400 uppercase"
          >
            Opening Hours
          </h3>
          <div class="flex flex-col gap-3">
            {
              hours.map((h) => (
                <div class="flex items-center justify-between border-b border-white/5 pb-3 last:border-0 last:pb-0">
                  <span class="text-sm font-medium text-white/80">
                    {h.days}
                  </span>
                  <span class="rounded-full bg-yellow-400/10 px-3 py-1 text-sm font-bold text-yellow-400">
                    {h.time}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <a
          href={directionsUrl}
          target="_blank"
          rel="noopener"
          class="rounded-full bg-yellow-400 py-3 text-center text-base font-bold text-black transition-all hover:scale-105 hover:bg-yellow-300"
        >
          Get Directions →
        </a>
      </div>
    </div>
  </div>
</section>
