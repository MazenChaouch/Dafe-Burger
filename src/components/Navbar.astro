---

---

<nav
  id="site-nav"
  class="fixed top-8 left-1/2 z-50 flex w-7xl -translate-x-1/2 items-center justify-between px-8 py-5"
>
  <!-- Title -->
  <div class="z-50 flex flex-col leading-none">
    <span class="text-[2vw] font-bold tracking-wide text-white">Dafe's</span>
    <span
      id="title-burger"
      class="-mt-0.5 translate-x-4 text-[2vw] font-bold tracking-wide text-yellow-400"
      >burger</span
    >
  </div>

  <!-- Menu button -->
  <button
    id="menu-btn"
    class="relative z-50 flex size-[3vw] cursor-pointer items-center justify-center rounded-full bg-yellow-400 transition-transform hover:scale-110"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="menu-overlay"
  >
    <svg
      class="size-[1.4vw]"
      viewBox="0 0 24 24"
      fill="none"
      stroke="black"
      stroke-width="2.5"
      stroke-linecap="round"
    >
      <line class="menu-line-top" x1="3" y1="6" x2="21" y2="6"></line>
      <line class="menu-line-mid" x1="3" y1="12" x2="21" y2="12"></line>
      <line class="menu-line-bot" x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>
</nav>

<!-- Full Screen Menu Overlay -->
<div
  id="menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="pointer-events-none fixed inset-0 z-40 flex flex-col items-center justify-center bg-yellow-400 opacity-0"
  style="clip-path: circle(0px at 0px 0px);"
>
  <ul
    class="flex flex-col gap-8 text-center text-[4vw] font-black text-black uppercase"
  >
    <li
      class="menu-link -translate-y-4 cursor-pointer opacity-0 transition-transform hover:scale-110"
    >
      <a href="/#slide-1" class="menu-item-link inline-block w-full">Home</a>
    </li>
    <li
      class="menu-link -translate-y-4 cursor-pointer opacity-0 transition-transform hover:scale-110"
    >
      <a href="/menu" class="menu-item-link inline-block w-full">Menu</a>
    </li>
    <li
      class="menu-link -translate-y-4 cursor-pointer opacity-0 transition-transform hover:scale-110"
    >
      <a href="/about" class="menu-item-link inline-block w-full">About Us</a>
    </li>
    <li
      class="menu-link -translate-y-4 cursor-pointer opacity-0 transition-transform hover:scale-110"
    >
      <a href="/#slide-5" class="menu-item-link inline-block w-full">Location</a
      >
    </li>
    <li
      class="menu-link -translate-y-4 cursor-pointer opacity-0 transition-transform hover:scale-110"
    >
      <a href="/#slide-6" class="menu-item-link inline-block w-full">Reviews</a>
    </li>
  </ul>
</div>

<script>
  import gsap from "gsap";
  import { store } from "../store";

  // ── Scope all selectors to the nav element to be safe if component
  //    is ever rendered multiple times or alongside other navs.
  const nav = document.querySelector<HTMLElement>("#site-nav")!;
  const menuBtn = document.querySelector<HTMLButtonElement>("#menu-btn")!;
  const menuOverlay = document.querySelector<HTMLElement>("#menu-overlay")!;
  const menuLinks = menuOverlay.querySelectorAll<HTMLElement>(".menu-link");
  const lineTop = nav.querySelector<SVGLineElement>(".menu-line-top")!;
  const lineMid = nav.querySelector<SVGLineElement>(".menu-line-mid")!;
  const lineBot = nav.querySelector<SVGLineElement>(".menu-line-bot")!;
  const titleBurger = nav.querySelector<HTMLElement>("#title-burger")!;
  const dotNavigator = document.getElementById("dot-navigator");

  let isMenuOpen = false;

  menuBtn.addEventListener("click", () => {
    store.toggle();
    isMenuOpen = store.isOpen;

    // Keep aria-expanded in sync with visual state
    menuBtn.setAttribute("aria-expanded", String(isMenuOpen));
    menuBtn.setAttribute(
      "aria-label",
      isMenuOpen ? "Close navigation menu" : "Open navigation menu",
    );

    // Get the exact centre coordinate of the button for the clip-path origin
    const rect = menuBtn.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;

    if (isMenuOpen) {
      // ── Open Menu ──
      gsap.set(menuOverlay, {
        opacity: 1,
        pointerEvents: "auto",
        clipPath: `circle(0px at ${x}px ${y}px)`,
      });

      const tl = gsap.timeline();

      tl.to(menuOverlay, {
        clipPath: `circle(150% at ${x}px ${y}px)`,
        duration: 0.8,
        ease: "expo.inOut",
      });

      tl.to(
        menuLinks,
        {
          opacity: 1,
          y: 0,
          duration: 0.4,
          stagger: 0.1,
          ease: "back.out(1.7)",
        },
        "-=0.3",
      );

      if (dotNavigator) {
        gsap.to(dotNavigator, {
          opacity: 0,
          pointerEvents: "none",
          duration: 0.3,
        });
      }

      // Morph hamburger → X
      gsap.to(lineTop, {
        y: 6,
        rotation: 45,
        transformOrigin: "center",
        duration: 0.4,
        ease: "power2.inOut",
      });
      gsap.to(lineMid, { opacity: 0, duration: 0.2 });
      gsap.to(lineBot, {
        y: -6,
        rotation: -45,
        transformOrigin: "center",
        duration: 0.4,
        ease: "power2.inOut",
      });

      // 'burger' text → black (contrasts yellow overlay)
      gsap.to(titleBurger, {
        color: "#000000",
        duration: 0.4,
        delay: 0.5,
        ease: "power2.inOut",
      });
    } else {
      // ── Close Menu ──
      const tl = gsap.timeline({
        onComplete: () => {
          gsap.set(menuOverlay, { opacity: 0, pointerEvents: "none" });
        },
      });

      tl.to(menuLinks, {
        opacity: 0,
        y: -10,
        duration: 0.3,
        stagger: -0.05,
        ease: "power2.in",
      });

      tl.to(
        menuOverlay,
        {
          clipPath: `circle(0px at ${x}px ${y}px)`,
          duration: 0.7,
          ease: "power3.inOut",
        },
        "-=0.1",
      );

      // Morph X → hamburger
      if (dotNavigator) {
        gsap.to(dotNavigator, {
          opacity: 1,
          pointerEvents: "auto",
          duration: 0.3,
          delay: 0.4,
        });
      }

      gsap.to([lineTop, lineMid, lineBot], {
        y: 0,
        rotation: 0,
        opacity: 1,
        transformOrigin: "center",
        duration: 0.4,
        ease: "power2.inOut",
      });

      // 'burger' text → yellow
      gsap.to(titleBurger, {
        color: "#facc15",
        duration: 0.4,
        delay: 0.1,
        ease: "power2.inOut",
      });
    }
  });

  // Close the menu automatically when a link inside it is clicked
  const itemLinks = menuOverlay.querySelectorAll(".menu-item-link");
  itemLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) {
        menuBtn.click();
      }
    });
  });
</script>
