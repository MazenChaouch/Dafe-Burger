---
import { Image } from "astro:assets";
import { CHIPS_DATA } from "../data/chipsData";

const chips = CHIPS_DATA;

/**
 * Single source of truth for each chip:
 * rendering properties (size, blur) + animation targets (open/closed positions).
 */
interface ChipData {
  src: ImageMetadata;
  alt: string;
  /** Display size in vw */
  size: number;
  /** Whether to apply a blur filter (depth-of-field effect) */
  blur: boolean;
  /** Horizontal offset (vw) when open */
  openX: number;
  /** Vertical offset (vw) when open */
  openY: number;
  /** Horizontal offset (vw) when closed */
  closedX: number;
  /** Vertical offset (vw) when closed */
  closedY: number;
}
---

<div class="chips-container flex items-center justify-center">
  {
    chips.map((chip) => (
      <div class="chip-entrance absolute">
        <div class="chip-wrapper">
          <Image
            src={chip.src}
            alt={chip.alt}
            class={`chip-item object-contain${chip.blur ? " blur-xs" : ""}`}
            style={`width: ${chip.size}vw; height: ${chip.size}vw;`}
          />
        </div>
      </div>
    ))
  }
</div>

<script>
  import gsap from "gsap";
  import { burgerStore } from "../store";

  document.addEventListener("astro:page-load", () => {
    // Mirror of the frontmatter data for the client-side animation.
    // A future improvement could pass this via data-attributes to eliminate
    // the duplication entirely.
    const chipsData = [
      { openX: -26, openY: 8, closedX: -18, closedY: 7 },
      { openX: -23, openY: -2, closedX: -18, closedY: -1 },
      { openX: -20, openY: -12, closedX: -15, closedY: -11.7 },
      { openX: -6, openY: -20.3, closedX: -4, closedY: -16 },
      { openX: 5, openY: -19, closedX: 8, closedY: -14.6 },
      { openX: 18, openY: -14.1, closedX: 17, closedY: -9 },
      { openX: 20, openY: -4, closedX: 18, closedY: -3 },
      { openX: 25, openY: 10, closedX: 15, closedY: 8 },
    ];

    // ── Init & Animation per container ──
    const containers =
      document.querySelectorAll<HTMLElement>(".chips-container");

    containers.forEach((container) => {
      // ── DOM refs scoped to this container instance ──
      const entranceEls =
        container.querySelectorAll<HTMLElement>(".chip-entrance");
      const wrapperEls =
        container.querySelectorAll<HTMLElement>(".chip-wrapper");
      const chipEls = container.querySelectorAll<HTMLElement>(".chip-item");

      // ── Init: apply closed positions via CSS (no GSAP) ──
      // Must run before the entrance animation so gsap.from() isn't overwritten.
      wrapperEls.forEach((el, i) => {
        const d = chipsData[i];
        el.style.transform = `translateX(${d.closedX}vw) translateY(${d.closedY}vw)`;
      });

      let entranceTl: gsap.core.Timeline | null = null;
      let floatTweens: gsap.core.Tween[] = [];

      // ── Entrance animation on scroll ──
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Kill existing timelines/tweens if any
              if (entranceTl) entranceTl.kill();
              floatTweens.forEach((t) => t.kill());
              floatTweens = [];

              entranceTl = gsap.timeline();

              entranceTl.fromTo(
                entranceEls,
                { y: -window.innerHeight, autoAlpha: 0 },
                {
                  y: 0,
                  autoAlpha: 1,
                  duration: 1.5,
                  ease: "power3.out",
                  stagger: { each: 0.05, from: "random" },
                },
              );

              // Add new float tweens after entrance
              entranceTl.add(() => {
                chipEls.forEach((chip) => {
                  const tween = gsap.to(chip, {
                    x: gsap.utils.random(-15, 15),
                    y: gsap.utils.random(-15, 15),
                    rotation: gsap.utils.random(-15, 15),
                    duration: 1,
                    ease: "sine.inOut",
                    repeat: -1,
                    yoyo: true,
                  });
                  floatTweens.push(tween);
                });
              });
            }
          });
        },
        { threshold: 0.1 },
      );

      const startObservation = () => {
        observer.observe(container);
      };

      const win = window as any;
      if (win.__loaderDone) {
        startObservation();
      } else {
        document.addEventListener("loader:complete", startObservation, {
          once: true,
        });
      }

      // ── React to open/close (store fires immediately with current state) ──
      const unsubscribe = burgerStore.subscribe((isOpen: boolean) => {
        wrapperEls.forEach((el, i) => {
          const d = chipsData[i];
          gsap.to(el, {
            x: `${isOpen ? d.openX : d.closedX}vw`,
            y: `${isOpen ? d.openY : d.closedY}vw`,
            duration: 0.6,
            ease: "back.out(1.7)",
            overwrite: "auto",
          });
        });
      });

      // Clean up on page unload (important for View Transitions)
      document.addEventListener("astro:before-swap", unsubscribe, {
        once: true,
      });
    });
  });
</script>
