---
// Slide 6 – Testimonials
const reviews = [
  { quote: "The harissa burger changed my life 🔥", name: "Karim B.", stars: 5, initials: "KB", color: "bg-red-500" },
  { quote: "Freshest patties in the city, hands down.", name: "Amina M.", stars: 5, initials: "AM", color: "bg-emerald-500" },
  { quote: "Fries are dangerously good. Went back 3 times.", name: "Mehdi T.", stars: 5, initials: "MT", color: "bg-yellow-500" },
  { quote: "Perfect late-night spot. Open late, worth it!", name: "Sarah K.", stars: 5, initials: "SK", color: "bg-purple-500" },
];
---

<section
  id="slide-6"
  class="snap-section relative flex h-screen w-full shrink-0 snap-start items-center justify-center overflow-hidden bg-[#181818]"
>
  <!-- Background accent -->
  <div aria-hidden="true" class="pointer-events-none absolute top-1/2 left-1/2 h-150 w-150 -translate-x-1/2 -translate-y-1/2 rounded-full bg-yellow-400/3 blur-[120px]"></div>

  <div class="relative z-10 flex w-full max-w-5xl flex-col items-center gap-10 px-8">
    <div class="flex flex-col items-center gap-2 text-center">
      <span class="text-sm font-semibold tracking-[0.3em] text-yellow-400 uppercase">Reviews</span>
      <h2 class="main-text text-[6vh] font-black text-white">
        What People Are <span class="text-yellow-400">Saying</span>
      </h2>
      <p class="text-sm text-white/40">Real reviews from real Tunis food lovers</p>
    </div>

    <!-- Review grid -->
    <div class="grid w-full grid-cols-2 gap-5">
      {reviews.map((r, i) => (
        <div
          class="review-card flex flex-col gap-4 rounded-2xl border border-white/8 bg-white/4 p-6 backdrop-blur-sm transition-all hover:border-yellow-400/30 hover:bg-white/8"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <!-- Stars -->
          <div class="flex gap-1 text-yellow-400">
            {"★★★★★".split("").map(() => <span class="text-base">★</span>)}
          </div>

          <!-- Quote -->
          <p class="text-base leading-relaxed text-white/80 italic">
            "{r.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 mt-auto">
            <div class={`flex size-9 items-center justify-center rounded-full text-sm font-bold text-white ${r.color}`}>
              {r.initials}
            </div>
            <span class="text-sm font-semibold text-white/60">{r.name}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Rating summary -->
    <div class="flex items-center gap-4 rounded-full border border-white/10 bg-white/5 px-8 py-3 backdrop-blur-sm">
      <span class="text-3xl font-black text-yellow-400">5.0</span>
      <div class="h-8 w-px bg-white/10"></div>
      <div class="flex flex-col">
        <span class="text-sm font-bold text-white">★★★★★</span>
        <span class="text-xs text-white/40">Based on 200+ reviews</span>
      </div>
      <div class="h-8 w-px bg-white/10"></div>
      <span class="text-sm text-white/60">Google · TripAdvisor</span>
    </div>
  </div>
</section>
