---
import { Image } from "astro:assets";
import { BURGER_LAYERS } from "../data/burgerLayers";
const layers = BURGER_LAYERS;
---

<div
  class="pointer-events-none absolute inset-0 flex items-center justify-center"
>
  <button
    class="burger-container pointer-events-auto relative cursor-pointer"
    aria-label="Toggle burger ingredients"
  >
    {
      layers.map((layer, i) => {
        const isLeft = i % 2 === 0;
        return (
          <div class="burger-layer relative">
            <Image
              src={layer.src}
              alt={layer.alt}
              class="burger-item w-[14vw] object-contain"
            />
            <div
              class={`layer-label pointer-events-none absolute top-1/2 flex -translate-y-1/2 items-center ${
                isLeft
                  ? "right-[calc(100%-1.25vw)] flex-row-reverse"
                  : "left-[calc(100%-1.25vw)] flex-row"
              }`}
            >
              <div class="size-[0.7vw] shrink-0 rounded-full bg-white" />
              <div class="h-0.5 w-[6vw] shrink-0 bg-white" />
              <div
                class={`flex flex-col gap-[0.2vw] ${
                  isLeft ? "items-end text-right" : "items-start text-left"
                }`}
              >
                {/* Text is set via JS so screenreaders already have the alt */}
                <span
                  class="label-name text-[1.2vw] leading-none font-extrabold tracking-widest whitespace-nowrap text-white uppercase"
                  aria-hidden="true"
                />
                <span
                  class="label-cal text-[0.9vw] leading-none font-medium whitespace-nowrap text-white/75"
                  aria-hidden="true"
                />
              </div>
            </div>
          </div>
        );
      })
    }

    <!--
    buy-now-btn: width starts at 0 (managed entirely by GSAP).
    The Tailwind width class is intentionally omitted here to avoid
    conflicting with GSAP's width animation.
  -->
    <div
      class="buy-now-btn pointer-events-none mx-auto mt-[3vw] overflow-hidden rounded-full bg-yellow-400 py-[0.6vw] text-center text-[1.1vw] font-bold tracking-wider text-black uppercase"
      style="width: 0;"
    >
      <span class="whitespace-nowrap">Buy Now</span>
    </div>
  </button>
</div>

<script>
  import gsap from "gsap";
  import { burgerStore } from "../store";

  document.addEventListener("astro:page-load", () => {
    // ── Layer animation data is now defined in the Astro frontmatter.
    // We read it from data-attributes or replicate just the numeric values here.
    // Since Astro renders server-side, we keep the JS array in sync with the
    // frontmatter definition — a future improvement would pass it via data-attrs.
    const layers = [
      { openY: -4, closedY: 5.6, z: 50, label: "Top Bun", cal: "120 kcal" },
      { openY: -3, closedY: 4.0, z: 40, label: "Tomato", cal: "5 kcal" },
      { openY: -2, closedY: 3.0, z: 30, label: "Onions", cal: "10 kcal" },
      { openY: -1, closedY: 2.0, z: 20, label: "Cheese", cal: "80 kcal" },
      { openY: 0, closedY: 0.0, z: 10, label: "Beef Patty", cal: "250 kcal" },
      { openY: 1, closedY: -1.0, z: 0, label: "Lettuce", cal: "3 kcal" },
      { openY: 2, closedY: -2.0, z: 10, label: "Bottom Bun", cal: "120 kcal" },
    ];

    // ── Init & Animation per container ──
    const containers =
      document.querySelectorAll<HTMLElement>(".burger-container");

    containers.forEach((container) => {
      // ── DOM refs scoped to this container instance ──
      const layerEls = container.querySelectorAll<HTMLElement>(".burger-layer");
      const itemEls = container.querySelectorAll<HTMLElement>(".burger-item");
      const labelEls = container.querySelectorAll<HTMLElement>(".layer-label");
      const buyNowBtn = container.querySelector<HTMLElement>(".buy-now-btn");

      // ── Init: set closed positions directly via CSS (no GSAP) ──
      // This must run before the entrance animation so gsap.from() can animate
      // in from off-screen without a concurrent tween overwriting it.
      layerEls.forEach((el, i) => {
        el.style.zIndex = String(layers[i].z);
        el.style.transform = `translateY(${layers[i].closedY}vw)`;
      });

      labelEls.forEach((el, i) => {
        el.querySelector<HTMLElement>(".label-name")!.textContent =
          layers[i].label;
        el.querySelector<HTMLElement>(".label-cal")!.textContent =
          layers[i].cal;
        // gsap.set is zero-duration and doesn't create a conflicting tween
        gsap.set(el, { autoAlpha: 0, x: i % 2 === 0 ? -30 : 30 });
      });

      // ── Click → toggle shared state ──
      container.addEventListener("click", (e) => {
        e.stopPropagation();
        burgerStore.toggle();
      });

      let bounceTween: gsap.core.Tween | null = null;
      let entranceTl: gsap.core.Timeline | null = null;

      // ── Entrance animation on scroll ──
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Kill existing animations if any
              if (bounceTween) bounceTween.kill();
              if (entranceTl) entranceTl.kill();

              // Reset container position before new bounce
              gsap.set(container, { y: 0 });

              entranceTl = gsap.timeline();

              // Re-run the drop-in animation
              entranceTl.fromTo(
                itemEls,
                { y: -window.innerHeight, autoAlpha: 0 },
                {
                  y: 0,
                  autoAlpha: 1,
                  duration: 1.8,
                  ease: "power3.out",
                  stagger: { each: 0.07, from: "end" },
                  onStart: () => {
                    // If open during page-load (unlikely, but safe), setup labels too
                    if (burgerStore.isOpen) {
                      const layerElsRe =
                        container.querySelectorAll<HTMLElement>(
                          ".burger-layer",
                        );
                      const labelElsRe =
                        container.querySelectorAll<HTMLElement>(".layer-label");
                      labelElsRe.forEach((el, i) => {
                        gsap.fromTo(
                          el,
                          { autoAlpha: 0, y: -window.innerHeight },
                          {
                            autoAlpha: 1,
                            y: 0,
                            duration: 1.8,
                            ease: "power3.out",
                            delay: (layerElsRe.length - i - 1) * 0.07,
                          },
                        );
                      });
                    }
                  },
                },
              );

              // Start idle bounce after entrance completes
              bounceTween = gsap.to(container, {
                y: "-2vw",
                duration: 1,
                delay: 1.8 + layerEls.length * 0.07 + 1, // timeline duration + 1s rest
                ease: "sine.inOut",
                repeat: -1,
                yoyo: true,
              });
            }
          });
        },
        { threshold: 0.1 }, // Trigger when 10% is visible
      );

      const startObservation = () => {
        observer.observe(container);
      };

      const win = window as any;
      if (win.__loaderDone) {
        startObservation();
      } else {
        document.addEventListener("loader:complete", startObservation, {
          once: true,
        });
      }

      // ── React to open/close (store fires immediately with current state) ──
      const unsubscribe = burgerStore.subscribe((isOpen) => {
        // 1. Animate layer positions
        layerEls.forEach((el, i) => {
          gsap.to(el, {
            y: `${isOpen ? layers[i].openY : layers[i].closedY}vw`,
            duration: 0.6,
            ease: "back.out(1.7)",
            overwrite: true,
          });
        });

        // 2. Animate labels in / out
        labelEls.forEach((el, i) => {
          const dir = i % 2 === 0 ? -30 : 30;
          if (isOpen) {
            gsap.fromTo(
              el,
              { autoAlpha: 0, x: dir, scale: 0.8 },
              {
                autoAlpha: 1,
                x: 0,
                scale: 1,
                duration: 0.6,
                delay: 0.3 + i * 0.08,
                ease: "back.out(1.7)",
                overwrite: true,
              },
            );
          } else {
            gsap.to(el, {
              autoAlpha: 0,
              x: dir,
              scale: 0.8,
              duration: 0.4,
              ease: "power2.in",
              overwrite: true,
            });
          }
        });

        // 3. Handle idle bounce (killing and recreating is safer than pause/resume due to overwrites)
        if (isOpen) {
          if (bounceTween) bounceTween.kill();
          gsap.to(container, {
            y: 0,
            duration: 0.4,
            ease: "power2.out",
            overwrite: "auto",
          });
        } else {
          if (bounceTween) {
            bounceTween = gsap.to(container, {
              y: "-2vw",
              duration: 1,
              ease: "sine.inOut",
              repeat: -1,
              yoyo: true,
            });
          }
        }

        // 4. Show / hide Buy Now button
        if (buyNowBtn) {
          if (isOpen) {
            gsap.fromTo(
              buyNowBtn,
              { y: "-4vw", autoAlpha: 0, width: 0 },
              {
                y: "2.5vw",
                autoAlpha: 1,
                width: "14vw",
                duration: 0.4,
                ease: "power2.out",
                pointerEvents: "auto",
                overwrite: true,
              },
            );
          } else {
            gsap.to(buyNowBtn, {
              y: 0,
              autoAlpha: 0,
              width: 0,
              duration: 0.2,
              ease: "power2.in",
              pointerEvents: "none",
              overwrite: true,
            });
          }
        }
      });

      // Clean up on page unload (important for View Transitions)
      document.addEventListener("astro:before-swap", unsubscribe, {
        once: true,
      });
    });
  });
</script>
