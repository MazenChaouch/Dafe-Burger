---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Chips from "../components/Chips.astro";
import Burger from "../components/Burger.astro";

import SlideMenu from "../components/SlideMenu.astro";
import SlideLocation from "../components/SlideLocation.astro";
import SlideTestimonials from "../components/SlideTestimonials.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Layout>
  <Navbar />

  <!-- Dot Navigation -->
  <div
    id="dot-navigator"
    class="fixed top-1/2 left-12 z-50 flex -translate-y-1/2 flex-col gap-6 rounded-full bg-black/10 px-6 py-8 shadow-xs inset-shadow-xs shadow-yellow-400 inset-shadow-yellow-400 backdrop-blur-sm transition-opacity duration-300"
  >
    <a
      href="#slide-1"
      class="nav-dot h-3 w-3 scale-125 rounded-full border border-yellow-400 bg-yellow-400"
      aria-label="Home"></a>
    <a
      href="#slide-2"
      class="nav-dot h-3 w-3 scale-100 rounded-full border border-yellow-400 bg-transparent"
      aria-label="About Us"></a>
    <a
      href="#slide-4"
      class="nav-dot h-3 w-3 scale-100 rounded-full border border-yellow-400 bg-transparent"
      aria-label="Menu Preview"></a>
    <a
      href="#slide-5"
      class="nav-dot h-3 w-3 scale-100 rounded-full border border-yellow-400 bg-transparent"
      aria-label="Location"></a>
    <a
      href="#slide-6"
      class="nav-dot h-3 w-3 scale-100 rounded-full border border-yellow-400 bg-transparent"
      aria-label="Reviews"></a>
  </div>

  <div
    class="scroll-container h-screen w-full snap-y snap-mandatory overflow-x-hidden overflow-y-auto scroll-smooth"
  >
    <!-- Red Page / Slide 1 -->
    <section
      id="slide-1"
      class="snap-section relative flex h-screen w-full shrink-0 snap-start items-center justify-center overflow-hidden bg-radial from-[#FF8686] to-[#FF0000] to-60%"
    >
      <!-- Decorative vertical text — presentational, not headings -->
      <p
        aria-hidden="true"
        class="absolute top-1/2 left-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:1px_white] [writing-mode:sideways-lr]"
      >
        YAMMY
      </p>
      <p
        aria-hidden="true"
        class="absolute top-1/2 right-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:1px_white] [writing-mode:vertical-rl]"
      >
        BURGER
      </p>

      <div class="w-fit">
        <!-- Single <h1> per page -->
        <h1
          class="main-text absolute top-[25%] left-1/2 -translate-x-1/2 -translate-y-1/2 text-[12vh] font-bold text-nowrap text-white"
        >
          The Best Burger in Town
        </h1>
        <Chips />
        <Burger />
        <div class="absolute top-[85%] left-1/2 -translate-x-1/2">
          <button
            id="toggle-hint"
            class="toggle-btn rounded-full bg-white px-4 py-1.5 font-semibold whitespace-nowrap text-black"
            >Click on burger</button
          >
        </div>
        <!-- Scroll indicator -->
        <div
          class="absolute top-[95%] left-1/2 -translate-x-1/2"
          aria-hidden="true"
        >
          <div class="h-8 w-5 rounded-2xl border-[3px] border-white">
            <div
              class="mx-auto size-1.5 translate-y-1 animate-bounce rounded-full bg-white"
            >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Green Page / Slide 2 -->
    <section
      id="slide-2"
      class="snap-section relative flex h-screen w-full shrink-0 snap-start items-center justify-center overflow-hidden bg-radial from-[#66D97A] to-[#0A8022] to-60%"
    >
      <!-- Decorative vertical text -->
      <p
        aria-hidden="true"
        class="absolute top-1/2 left-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:1px_white] [writing-mode:sideways-lr]"
      >
        YAMMY
      </p>
      <p
        aria-hidden="true"
        class="absolute top-1/2 right-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:1px_white] [writing-mode:vertical-rl]"
      >
        BURGER
      </p>

      <div class="w-fit">
        <h2
          class="main-text absolute top-[25%] left-1/2 -translate-x-1/2 -translate-y-1/2 text-[12vh] font-bold text-nowrap text-white"
        >
          Fresh Ingredients Always
        </h2>
        <Chips />
        <Burger />
        <div class="absolute top-[85%] left-1/2 -translate-x-1/2">
          <button
            class="toggle-btn rounded-full bg-white px-4 py-1.5 font-semibold whitespace-nowrap text-black"
            >Click on burger</button
          >
        </div>
      </div>
    </section>

    <SlideMenu />
    <SlideLocation />
    <SlideTestimonials />
    <SiteFooter />
  </div>
</Layout>

<script>
  import gsap from "gsap";
  import { store } from "../store";

  const mainTexts = document.querySelectorAll<HTMLElement>(".main-text");
  const toggleBtns = document.querySelectorAll<HTMLElement>(".toggle-btn");

  const sections = document.querySelectorAll<HTMLElement>(".snap-section");
  const footer = document.querySelector<HTMLElement>("footer");
  const navDots = document.querySelectorAll<HTMLAnchorElement>(".nav-dot");

  // ── Entrance on scroll & Navigation Update ──
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          const sectionId = target.getAttribute("id");

          // 1. Update navigation dots & URL hash (only for sections with IDs)
          if (sectionId) {
            // Update URL hash without jumping/adding to history stack
            history.replaceState(null, "", `#${sectionId}`);

            navDots.forEach((dot) => {
              const isMatch = dot.getAttribute("href") === `#${sectionId}`;
              if (isMatch) {
                dot.classList.add("bg-yellow-400", "scale-125");
                dot.classList.remove("bg-transparent", "scale-100");
              } else {
                dot.classList.remove("bg-yellow-400", "scale-125");
                dot.classList.add("bg-transparent", "scale-100");
              }
            });
          }

          // 2. Play main text entrance
          const mainText = target.querySelector(".main-text");
          if (mainText) {
            gsap.fromTo(
              mainText,
              { y: -100, opacity: 0 },
              {
                y: 0,
                opacity: 1,
                duration: 1.2,
                ease: "power4.out",
                overwrite: true,
              },
            );
          }

          // 3. Staggered cards (Slide 4 & 6)
          const cards = target.querySelectorAll(".burger-card, .review-card");
          if (cards.length > 0) {
            gsap.fromTo(
              cards,
              { y: 60, opacity: 0 },
              {
                y: 0,
                opacity: 1,
                duration: 0.8,
                stagger: 0.15,
                ease: "power2.out",
                delay: 0.3,
                overwrite: true,
              },
            );
          }

          // 4. Footer "Height Growth" animation
          if (target.tagName === "FOOTER") {
            gsap.fromTo(
              target,
              { paddingTop: "4rem", paddingBottom: "4rem" },
              {
                paddingTop: "13rem",
                paddingBottom: "16rem",
                duration: 1.5,
                ease: "expo.out",
                overwrite: true,
              },
            );
          }
        }
      });
    },
    { threshold: 0.2 }, // Lower threshold to trigger animations earlier
  );

  sections.forEach((s) => observer.observe(s));
  if (footer) observer.observe(footer);

  // ── React to open/close (store fires immediately with current state) ──
  const unsubscribe = store.subscribe((isOpen) => {
    // Slide main texts off-screen to the top
    mainTexts.forEach((mainText) => {
      gsap.to(mainText, {
        y: isOpen ? -window.innerHeight : 0,
        opacity: isOpen ? 0 : 1,
        duration: 0.7,
        ease: isOpen ? "sine.out" : "back.out(1)",
        overwrite: true,
      });
    });

    // Hide / show "Click on burger" hint
    toggleBtns.forEach((toggleBtn) => {
      gsap.to(toggleBtn, {
        opacity: isOpen ? 0 : 1,
        y: isOpen ? 20 : 0,
        duration: 0.3,
        delay: isOpen ? 0 : 0.2,
        pointerEvents: isOpen ? "none" : "auto",
        overwrite: true,
      });
    });
  });

  document.addEventListener("astro:before-swap", unsubscribe, { once: true });
</script>
