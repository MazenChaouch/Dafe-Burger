---
import Navbar from "../components/Navbar.astro";
import Chips from "../components/Chips.astro";
import Burger from "../components/Burger.astro";
import "../styles/global.css";
---

<Navbar />

<div
  class="h-screen w-full snap-y snap-mandatory overflow-x-hidden overflow-y-auto scroll-smooth"
>
  <!-- Red Page / Slide 1 -->
  <section
    class="relative flex h-screen w-full shrink-0 snap-start items-center justify-center overflow-hidden bg-radial from-[#FF8686] to-[#FF0000] to-60%"
  >
    <h1
      class="absolute top-1/2 left-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:0.5px_white] [writing-mode:sideways-lr]"
    >
      YAMMY
    </h1>
    <h1
      class="absolute top-1/2 right-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:0.5px_white] [writing-mode:vertical-rl]"
    >
      BURGER
    </h1>
    <div class="w-fit">
      <h1
        class="main-text absolute top-[15%] left-1/2 -translate-x-1/2 -translate-y-1/2 text-[25dvh] font-bold text-nowrap text-white sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl"
      >
        The Best Burger in Town
      </h1>
      <Chips />
      <Burger />
      <div class="absolute top-[85%] left-1/2 -translate-x-1/2">
        <button
          class="toggle-btn rounded-full bg-white px-4 py-1.5 font-semibold whitespace-nowrap text-black"
          >Click on burger</button
        >
      </div>
      <div class="absolute top-[95%] left-1/2 -translate-x-1/2">
        <div class="h-8 w-5 rounded-2xl border-[3px] border-white">
          <div
            class="mx-auto size-1.5 translate-y-1 animate-bounce rounded-full bg-white"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Green Page / Slide 2 -->
  <section
    class="relative flex h-screen w-full shrink-0 snap-start items-center justify-center overflow-hidden bg-radial from-[#66D97A] to-[#0A8022] to-60%"
  >
    <h1
      class="absolute top-1/2 left-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:0.5px_white] [writing-mode:sideways-lr]"
    >
      YAMMY
    </h1>
    <h1
      class="absolute top-1/2 right-[12%] -translate-y-1/2 text-[28dvh] leading-none font-bold text-transparent [-webkit-text-stroke:0.5px_white] [writing-mode:vertical-rl]"
    >
      BURGER
    </h1>
    <div class="w-fit">
      <h1
        class="main-text absolute top-[15%] left-1/2 -translate-x-1/2 -translate-y-1/2 text-[25dvh] font-bold text-nowrap text-white sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl"
      >
        Fresh Ingredients Always
      </h1>
      <Chips />
      <Burger />
      <div class="absolute top-[85%] left-1/2 -translate-x-1/2">
        <button
          class="toggle-btn rounded-full bg-white px-4 py-1.5 font-semibold whitespace-nowrap text-black"
          >Click on burger</button
        >
      </div>
    </div>
  </section>
</div>

<script>
  import gsap from "gsap";
  import { store } from "../store";

  const mainTexts = document.querySelectorAll(".main-text");
  const toggleBtns = document.querySelectorAll(".toggle-btn");

  // ── Main text entrance ──
  mainTexts.forEach((mainText) => {
    gsap.from(mainText, {
      y: -window.innerHeight,
      opacity: 0,
      duration: 1.5,
      ease: "power3.out",
    });
  });

  // ── React to open/close ──
  store.subscribe((isOpen) => {
    // Slide main texts off-screen to top
    mainTexts.forEach((mainText) => {
      gsap.to(mainText, {
        y: isOpen ? -window.innerHeight : 0,
        opacity: isOpen ? 0 : 1,
        duration: 0.7,
        ease: isOpen ? "sine.out" : "back.out(1)",
        overwrite: true,
      });
    });

    // Hide/show all "Click on burger" buttons
    toggleBtns.forEach((toggleBtn) => {
      gsap.to(toggleBtn, {
        opacity: isOpen ? 0 : 1,
        y: isOpen ? 20 : 0,
        duration: 0.3,
        delay: isOpen ? 0 : 0.2,
        pointerEvents: isOpen ? "none" : "auto",
        overwrite: true,
      });
    });
  });
</script>
