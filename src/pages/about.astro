---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { ABOUT_DATA } from "../data/about";
const { hero, story, values } = ABOUT_DATA;
---

<Layout title={`About Us | Dafe's Burger`}>
  <Navbar />

  <main
    class="relative min-h-screen overflow-hidden bg-emerald-800 pt-32 pb-20"
  >
    {/* Background Text */}
    <p
      aria-hidden="true"
      class="bg-text pointer-events-none absolute top-1/2 left-[5%] -translate-y-1/2 text-[40dvh] leading-none font-bold text-transparent [-webkit-text-stroke:1px_rgba(255,255,255,0.1)] [writing-mode:vertical-rl]"
    >
      {hero.bgText}
    </p>

    <div class="relative z-10 mx-auto max-w-6xl px-8">
      {/* Hero Section */}
      <div class="mb-32 flex flex-col items-center text-center">
        <h1
          class="hero-title text-8xl leading-none font-black tracking-tighter text-white uppercase md:text-[15rem]"
        >
          {hero.title}
        </h1>
        <p
          class="hero-subtitle mt-4 text-3xl font-bold tracking-[0.3em] text-yellow-400 uppercase"
        >
          {hero.subtitle}
        </p>
      </div>

      {/* Story Grid */}
      <div class="grid items-center gap-20 md:grid-cols-2">
        <div class="story-content flex flex-col gap-8">
          <h2 class="text-5xl leading-tight font-black text-white">
            {story.title}
            <br />
            <span class="text-yellow-400">{story.titleAccent}</span>
          </h2>
          {
            story.paragraphs.map((p) => (
              <p class="text-lg leading-relaxed text-white/70">{p}</p>
            ))
          }

          <div class="mt-6 flex gap-10">
            {
              story.stats.map((s) => (
                <div class="flex flex-col">
                  <span class="text-5xl font-black text-yellow-400">
                    {s.value}
                  </span>
                  <span class="text-sm font-bold tracking-widest text-white/50 uppercase">
                    {s.label}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="story-image relative">
          <div
            class="group flex aspect-square items-center justify-center overflow-hidden rounded-4xl border border-white/10 bg-emerald-700/50"
          >
            <div
              class="text-9xl font-black text-white/20 transition-transform duration-700 group-hover:scale-110"
            >
              {story.imagePlaceholder}
            </div>
          </div>
          <div
            class="absolute -bottom-10 -left-10 rotate-3 rounded-3xl bg-yellow-400 p-8 shadow-2xl"
          >
            <p class="text-xl font-black text-black uppercase italic">
              "{story.testimonial.text}"
            </p>
            <p class="text-sm font-bold text-black/60">
              - {story.testimonial.author}
            </p>
          </div>
        </div>
      </div>

      {/* Values */}
      <div class="mt-40 grid gap-12 md:grid-cols-3">
        {
          values.map((v) => (
            <div class="value-card flex flex-col gap-4 rounded-4xl border border-white/5 bg-white/5 p-8 backdrop-blur-sm">
              <span class="text-4xl">{v.emoji}</span>
              <h3 class="text-2xl font-black text-white uppercase">
                {v.title}
              </h3>
              <p class="text-sm leading-relaxed text-white/50">
                {v.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </main>

  <SiteFooter />
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function initAnimations() {
    // Kill any existing ScrollTriggers from previous page visits
    ScrollTrigger.getAll().forEach((t) => t.kill());

    // Clear ALL leftover GSAP inline styles from a previous visit.
    // This guarantees every element starts at its natural visible CSS state.
    gsap.set(
      ".hero-title, .hero-subtitle, .bg-text, .story-content, .story-image, .value-card",
      { clearProps: "all" },
    );

    // ── Single entrance timeline for everything above the fold ──
    // No ScrollTrigger = no risk of elements getting stuck invisible.
    const tl = gsap.timeline({ delay: 0.1 });

    tl.fromTo(
      ".hero-title",
      { y: 30, autoAlpha: 0 },
      { y: 0, autoAlpha: 1, duration: 1, ease: "expo.out" },
    )
      .fromTo(
        ".hero-subtitle",
        { y: 15, autoAlpha: 0 },
        { y: 0, autoAlpha: 1, duration: 0.7, ease: "expo.out" },
        "-=0.7",
      )
      .fromTo(
        ".bg-text",
        { x: -20, autoAlpha: 0 },
        { x: 0, autoAlpha: 1, duration: 1.5, ease: "expo.out" },
        0,
      )
      .fromTo(
        ".story-content",
        { y: 30, autoAlpha: 0 },
        { y: 0, autoAlpha: 1, duration: 1, ease: "expo.out" },
        "-=0.6",
      )
      .fromTo(
        ".story-image",
        { scale: 0.96, autoAlpha: 0 },
        { scale: 1, autoAlpha: 1, duration: 1, ease: "expo.out" },
        "-=0.7",
      );

    // ── Value cards: these are far below the fold, so ScrollTrigger is safe ──
    gsap.from(".value-card", {
      scrollTrigger: {
        trigger: ".value-card",
        start: "top 98%",
        toggleActions: "play none none none",
      },
      y: 30,
      opacity: 0,
      duration: 0.7,
      stagger: 0.1,
      ease: "expo.out",
      immediateRender: false,
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener("astro:page-load", () => {
    const win = window as Window & { __loaderDone?: boolean };

    setTimeout(() => {
      if (win.__loaderDone) {
        initAnimations();
      } else {
        document.addEventListener("loader:complete", () => initAnimations(), {
          once: true,
        });
      }
    }, 60);
  });
</script>
